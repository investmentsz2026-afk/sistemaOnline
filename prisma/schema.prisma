// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MODERATOR
  EMPLOYEE
  CLIENT
}

enum WithdrawalStatus {
  PENDING
  COMPLETED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  playerId      String?   @unique // ID de 6 dígitos único (ej: 102938)
  name          String?
  email         String    @unique
  password      String
  role          Role      @default(CLIENT)
  phoneNumber   String?
  company       String?
  image         String?
  isActive      Boolean   @default(true)
  balance       Float     @default(0.0)
  points        Int       @default(0)    // Puntos acumulados en batallas/misiones
  wins          Int       @default(0)    // Número de victorias totales
  lastSeen      DateTime  @default(now()) // Para "En Línea" / "Última vez"
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs     AuditLog[]
  withdrawals   Withdrawal[]
  completedMissions UserMission[]
  
  // Amistad
  friendsRequested   Friendship[] @relation("UserRequested")
  friendsReceived    Friendship[] @relation("UserReceived")
  
  // Chat
  sentMessages      Message[]
  conversations     ConversationParticipant[]
  notifications     Notification[]
  
  // Regalos
  sentGifts         GiftTransaction[] @relation("GiftSender")
  receivedGifts     GiftTransaction[] @relation("GiftReceiver")
  
  // Finanzas
  recharges         Recharge[]

  // Batallas
  battlesCreated    Battle[]          @relation("BattleCreator")
  battlesWon        Battle[]          @relation("BattleWinner")
  participations    BattleParticipant[]
  supportTickets    SupportTicket[]
  pointRedemptions  PointsRedemption[]
  gameProgress      GameProgress[]
  gameRankings      GameRanking[]

  @@map("users")
}

model Recharge {
  id              String   @id @default(cuid())
  userId          String
  amount          Float    // Monto recargado
  coins           Float    // Monedas otorgadas
  method          String   // "PAYPAL", "CARD", etc.
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED
  transactionId   String?  @unique // ID del proveedor de pago
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])

  @@map("recharges")
}

model Gift {
  id          String   @id @default(cuid())
  name        String
  price       Float    @default(0.0)
  icon        String   // Emoji o URL de imagen
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  transactions GiftTransaction[]

  @@map("gift_types")
}

model GiftTransaction {
  id              String   @id @default(cuid())
  giftId          String
  senderId        String
  receiverId      String
  amount          Float    // Precio total pagado por el emisor
  recipientGets   Float    // Lo que recibe el destinatario (después de comisión)
  platformFee     Float    // Comisión de la casa
  createdAt       DateTime @default(now())

  gift            Gift     @relation(fields: [giftId], references: [id])
  sender          User     @relation("GiftSender", fields: [senderId], references: [id])
  receiver        User     @relation("GiftReceiver", fields: [receiverId], references: [id])

  @@map("gift_transactions")
}

model Friendship {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt   DateTime @default(now())

  sender      User     @relation("UserRequested", fields: [senderId], references: [id])
  receiver    User     @relation("UserReceived", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@map("friendships")
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  participants ConversationParticipant[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  text           String?
  imageUrl       String?  // Soporte para fotos
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model Withdrawal {
  id          String           @id @default(cuid())
  userId      String
  amount      Float
  method      String           // e.g., "Binance", "PayPal", "Bank Transfer"
  accountInfo String           // Account details for payment
  status      WithdrawalStatus @default(PENDING)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id])

  @@map("withdrawals")
}

model UserMission {
  id        String   @id @default(cuid())
  userId    String
  missionId String   // e.g. "instagram_follow"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, missionId])
  @@map("user_missions")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  description String
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // FRIEND_REQUEST, REQUEST_ACCEPTED, NEW_MESSAGE
  title     String
  message   String
  link      String?  // URL para redirigir al hacer click
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Battle {
  id            String    @id @default(cuid())
  creatorId     String
  creator       User      @relation("BattleCreator", fields: [creatorId], references: [id])
  priceUsd      Float
  priceCoins    Float
  status        String    @default("WAITING") // WAITING, IN_PROGRESS, COMPLETED, CANCELLED
  winnerId      String?
  winner        User?     @relation("BattleWinner", fields: [winnerId], references: [id])
  totalPrize    Float     @default(0)
  accumulated   Float     @default(0) // Pozo que se suma si cae en "Acumulado"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  participants  BattleParticipant[]

  @@map("battles")
}

model BattleParticipant {
  id        String   @id @default(cuid())
  battleId  String
  userId    String
  position  Int      // Posición en la ruleta (0-5)
  createdAt DateTime @default(now())

  battle    Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([battleId, userId])
  @@unique([battleId, position])
  @@map("battle_participants")
}

model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  message     String
  status      String   @default("PENDING") // PENDING, RESOLVED
  reply       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_tickets")
}

model PointsRedemption {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointsAmount  Int
  bcAmount      Float
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("points_redemptions")
}

// Modelos de Juegos HTML5 Premium
model GameProgress {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId         String   // "runner" o "puzzle"
  level          Int      @default(1)
  xp             Int      @default(0)
  coins          Int      @default(0)
  highScore      Int      @default(0)
  skinsUnlocked  String   @default("default") // Lista separada por comas (ej: "default,neon_runner")
  currentSkin    String   @default("default")
  stats          String   @default("{}")      // Estadísticas serializadas en JSON string (ej: partidas jugadas, tiempo total, etc.)
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([userId, gameId])
  @@map("game_progress")
}

model GameMission {
  id          String   @id @default(cuid())
  gameId      String   // "runner" o "puzzle"
  title       String
  description String
  targetType  String   // "distance", "coins", "playTime", "score", "gamesPlayed"
  targetValue Int
  rewardCoins Int
  rewardXp    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("game_missions")
}

model UserGameMissionProgress {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  currentValue Int      @default(0)
  isCompleted  Boolean  @default(false)
  isClaimed    Boolean  @default(false)
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([userId, missionId])
  @@map("user_game_mission_progress")
}

model GameRanking {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String   // "runner" o "puzzle"
  score     Int
  level     Int      @default(1)
  createdAt DateTime @default(now())

  @@map("game_rankings")
}
