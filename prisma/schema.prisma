// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MODERATOR
  EMPLOYEE
  CLIENT
}

enum WithdrawalStatus {
  PENDING
  COMPLETED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          Role      @default(CLIENT)
  phoneNumber   String?
  company       String?
  image         String?
  isActive      Boolean   @default(true)
  balance       Float     @default(0.0)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  auditLogs     AuditLog[]
  withdrawals   Withdrawal[]
  completedMissions UserMission[]

  @@map("users")
}

model Withdrawal {
  id          String           @id @default(cuid())
  userId      String
  amount      Float
  method      String           // e.g., "Binance", "PayPal", "Bank Transfer"
  accountInfo String           // Account details for payment
  status      WithdrawalStatus @default(PENDING)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User             @relation(fields: [userId], references: [id])

  @@map("withdrawals")
}

model UserMission {
  id        String   @id @default(cuid())
  userId    String
  missionId String   // e.g. "instagram_follow"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, missionId])
  @@map("user_missions")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  description String
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
